# Server Configuration
SERVER_PORT=8080

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=forex_sim

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration (WAJIB DIGANTI!)
JWT_SECRET=your-super-secure-secret-key-min-32-characters

# ============================================
# FOREX DATA API - PILIH SALAH SATU
# ============================================

# OPSI 1: Frankfurter (GRATIS, RECOMMENDED!)
# - 100% Gratis
# - Tidak perlu API key
# - Data dari European Central Bank
# - Update: harian (reference rates)
# - URL: https://api.frankfurter.app
DATA_SOURCE=frankfurter

# OPSI 2: Alpha Vantage (Freemium)
# - Gratis: 25 requests/hari
# - Daftar: https://www.alphavantage.co/support/#api-key
# DATA_SOURCE=alpha_vantage
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key

# OPSI 3: OANDA (Berbayar/Practice)
# - Memerlukan akun practice
# - Daftar: https://www.oanda.com/
# DATA_SOURCE=oanda
# OANDA_API_KEY=your_oanda_key
# OANDA_ACCOUNT_ID=your_oanda_account_id

# ============================================
# DATABASE CONNECTION POOL (Optional)
# ============================================
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=10m

# ============================================
# SECURITY (Optional)
# ============================================
# BCRYPT_COST=12  # Higher = more secure but slower

# ============================================
# ML MODEL CONFIGURATION
# ============================================
MODEL_PATH=./models
